generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                  String  @id @default(cuid())
  userId              String  @map("user_id")
  type                String
  provider            String
  providerAccountId   String  @map("provider_account_id")
  refresh_token       String?
  access_token        String?
  expires_at          Int?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model BankImport {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  fileName             String   @map("file_name")
  totalTransactions    Int      @map("total_transactions")
  recurringDetected    Int      @map("recurring_detected")
  subscriptionsCreated Int      @map("subscriptions_created")
  createdAt            DateTime @default(now()) @map("created_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_imports")
}

model CancellationAttempt {
  id              String        @id @default(cuid())
  subscriptionId  String        @map("subscription_id")
  method          String?
  status          String        @default("pending")
  errorMessage    String?       @map("error_message")
  credentialsUsed Json?         @map("credentials_used")
  attemptedAt     DateTime      @default(now()) @map("attempted_at")
  completedAt     DateTime?     @map("completed_at")
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("cancellation_attempts")
}

model Category {
  id            String         @id @default(cuid())
  name          String
  userId        String?        @map("user_id")
  isPreset      Boolean        @default(false) @map("is_preset")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([name, userId])
  @@index([userId])
  @@map("categories")
}

model MerchantAlias {
  id          String @id @default(cuid())
  bankPattern String @unique @map("bank_pattern")
  serviceName String @map("service_name")

  @@map("merchant_aliases")
}

model PendingMerchantAlias {
  id                String    @id @default(cuid())
  bankPattern       String    @unique @map("bank_pattern")
  serviceName       String    @map("service_name")
  sampleDescription String    @map("sample_description")
  confidence        Float
  status            String    @default("pending")
  createdAt         DateTime  @default(now()) @map("created_at")
  reviewedAt        DateTime? @map("reviewed_at")

  @@index([status])
  @@map("pending_merchant_aliases")
}

model OpenSourceAlternative {
  id              String   @id @default(cuid())
  serviceName     String   @map("service_name")
  alternativeName String   @map("alternative_name")
  description     String
  websiteUrl      String?  @map("website_url")
  sourceCodeUrl   String?  @map("source_code_url")
  stars           Int      @default(0)
  license         String?
  category        String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([serviceName, alternativeName])
  @@index([serviceName])
  @@map("open_source_alternatives")
}

model PendingSubscription {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  serviceName     String    @map("service_name")
  confidence      Decimal   @db.Decimal(3, 2)
  amount          Decimal?  @db.Decimal(10, 2)
  currency        String    @default("USD")
  isTrial         Boolean   @default(false) @map("is_trial")
  trialEndsAt     DateTime? @map("trial_ends_at")
  nextBillingDate DateTime? @map("next_billing_date")
  emailId         String    @map("email_id")
  emailSubject    String    @map("email_subject")
  emailFrom       String    @map("email_from")
  emailDate       DateTime  @map("email_date")
  rawEmailData    Json?     @map("raw_email_data")
  status          String    @default("pending")
  createdAt       DateTime  @default(now()) @map("created_at")
  expiresAt       DateTime  @map("expires_at")
  billingCycle    String?   @map("billing_cycle")
  sourceType      String    @default("receipt") @map("source_type")
  noticeType      String?   @map("notice_type")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId, status])
  @@map("pending_subscriptions")
}

model PlaidItem {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  itemId          String         @unique @map("item_id")
  accessToken     String         @map("access_token")
  institutionName String?        @map("institution_name")
  cursor          String?
  lastSyncedAt    DateTime?      @map("last_synced_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts        PlaidAccount[]

  @@index([userId])
  @@map("plaid_items")
}

model PlaidAccount {
  id          String    @id @default(cuid())
  plaidItemId String    @map("plaid_item_id")
  accountId   String    @unique @map("account_id")
  name        String
  mask        String?
  type        String
  createdAt   DateTime  @default(now()) @map("created_at")
  plaidItem   PlaidItem @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)

  @@map("plaid_accounts")
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  endpointData Json     @map("endpoint_data")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@map("push_subscriptions")
}

model Reminder {
  id             String       @id @default(cuid())
  subscriptionId String       @map("subscription_id")
  reminderType   String       @map("reminder_type")
  scheduledFor   DateTime     @map("scheduled_for")
  sentAt         DateTime?    @map("sent_at")
  channelsUsed   String[]     @map("channels_used")
  jobId          String?      @map("job_id")
  status         String       @default("pending")
  createdAt      DateTime     @default(now()) @map("created_at")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([scheduledFor, status])
  @@index([subscriptionId])
  @@map("reminders")
}

model ServiceConfig {
  id                       String   @id @default(cuid())
  serviceName              String   @unique @map("service_name")
  hasApi                   Boolean  @default(false) @map("has_api")
  apiEndpoint              String?  @map("api_endpoint")
  apiAuthType              String?  @map("api_auth_type")
  loginUrl                 String?  @map("login_url")
  cancellationUrl          String?  @map("cancellation_url")
  cancelButtonSelector     String?  @map("cancel_button_selector")
  confirmSelector          String?  @map("confirm_selector")
  successIndicator         String?  @map("success_indicator")
  cancellationInstructions Json?    @map("cancellation_instructions")
  emailPatterns            Json?    @map("email_patterns")
  logoUrl                  String?  @map("logo_url")
  supportUrl               String?  @map("support_url")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("service_configs")
}

model SavingsGoal {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  name         String
  targetAmount Decimal   @db.Decimal(10, 2) @map("target_amount")
  currency     String    @default("USD")
  deadline     DateTime?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("savings_goals")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Subscription {
  id                   String                @id @default(cuid())
  userId               String                @map("user_id")
  serviceName          String                @map("service_name")
  status               String                @default("active")
  billingCycle         String?               @map("billing_cycle")
  amount               Decimal?              @db.Decimal(10, 2)
  currency             String                @default("USD")
  trialEndsAt          DateTime?             @map("trial_ends_at")
  nextBillingDate      DateTime?             @map("next_billing_date")
  description          String?               @map("description")
  cancellationUrl      String?               @map("cancellation_url")
  autoCancelEnabled    Boolean               @default(false) @map("auto_cancel_enabled")
  detectedFrom         String?               @map("detected_from")
  type                 SubscriptionType      @default(PERSONAL)
  categoryId           String?               @map("category_id")
  rawEmailData         Json?                 @map("raw_email_data")
  bankTransactionData  Json?                 @map("bank_transaction_data")
  externalId           String?               @map("external_id")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  reminderSettings     Json?                 @map("reminder_settings")
  cancelledAt          DateTime?             @map("cancelled_at")
  savedAmount          Decimal?              @db.Decimal(10, 2) @map("saved_amount")
  cancellationAttempts CancellationAttempt[]
  reminders            Reminder[]
  category             Category?             @relation(fields: [categoryId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([nextBillingDate])
  @@index([userId])
  @@index([userId, status])
  @@map("subscriptions")
}

model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  emailVerified           DateTime?             @map("email_verified")
  passwordHash            String?               @map("password_hash")
  name                    String?
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  oauthTokens             String?               @map("oauth_tokens")
  emailProvider           String?               @map("email_provider")
  tier                    String                @default("free")
  notificationPreferences Json                  @default("{\"sms\": false, \"push\": true, \"email\": true}") @map("notification_preferences")
  phoneNumber             String?               @map("phone_number")
  phoneVerified           Boolean               @default(false) @map("phone_verified")
  stripeCustomerId        String?               @unique @map("stripe_customer_id")
  homeCurrency            String                @default("USD") @map("home_currency")
  lastQuarterlyAuditEmailAt DateTime?           @map("last_quarterly_audit_email_at")
  householdOwnerId        String?               @map("household_owner_id")
  accounts                Account[]
  bankImports             BankImport[]
  savingsGoals            SavingsGoal[]
  plaidItems              PlaidItem[]
  categories              Category[]
  pendingSubscriptions    PendingSubscription[]
  pushSubscriptions       PushSubscription[]
  sessions                Session[]
  subscriptions           Subscription[]
  householdOwner          User?                 @relation("HouseholdMembership", fields: [householdOwnerId], references: [id], onDelete: SetNull)
  householdMembers        User[]                @relation("HouseholdMembership")
  sentHouseholdInvites    HouseholdInvite[]
  passwordResetTokens     PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model HouseholdInvite {
  id         String    @id @default(cuid())
  ownerId    String    @map("owner_id")
  email      String
  token      String    @unique
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([email])
  @@map("household_invites")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailUnsubscribe {
  email          String   @id
  reason         String?
  unsubscribedAt DateTime @default(now()) @map("unsubscribed_at")

  @@map("email_unsubscribes")
}

enum SubscriptionType {
  PERSONAL
  BUSINESS
}
