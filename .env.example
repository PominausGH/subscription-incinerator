# Database
DATABASE_URL="postgresql://user:password@localhost:5432/subscription_incinerator"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Encryption (for OAuth tokens) - generate with: openssl rand -base64 32
ENCRYPTION_SECRET="generate-with-openssl-rand-base64-32"

# Brevo (SMTP relay used by nodemailer)
BREVO_SMTP_USER="your_brevo_smtp_login"
BREVO_SMTP_KEY="your_brevo_smtp_key"

# Email From Address
# Use format: noreply@yourdomain.com or auth@yourdomain.com
# For Brevo: Must use a sender you've verified in the Brevo dashboard
EMAIL_FROM="noreply@localhost"

# App
APP_URL="http://localhost:3000"

# Admin (gates /admin pages - e.g. merchant alias review queue)
ADMIN_EMAIL="you@example.com"

# Gmail OAuth
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/oauth/gmail/callback"

# Plaid (for bank account linking)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Anthropic (for AI-powered CSV parsing)
ANTHROPIC_API_KEY="sk-ant-xxxxx"

# Stripe (for premium subscriptions)
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"
STRIPE_PRICE_ID="price_xxxxx"

# Public URLs (needed for redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Push Notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Marketing OS Admin Password
ADMIN_MARKETING_PASSWORD="your-strong-admin-password"

